# =========================================================
# SENTINEL IOC — .gitignore
# =========================================================

# Virtual environments
venv/
.venv/
env/
.env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# IOC output files (may contain sensitive data)
*.iocs.json
iocs_output.json

# API keys / secrets
.env
*.env
secrets.txt
config.ini
config.yaml
config.yml

# Logs and test input files (may contain sensitive IOCs)
*.log
*.txt
!README.txt

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml
